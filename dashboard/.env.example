# ─── Dashboard environment (copy to .env.local) ─────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=replace-with-a-long-random-string
# NextAuth v5 trusts the deployment host; set your URL in prod.
# AUTH_URL=https://your-app.vercel.app

# Single-user credentials. Set EITHER a plaintext password (simplest) OR a hash.
DASHBOARD_USERNAME=alex
# Simplest — plaintext password (fine for a private, single-user tool):
DASHBOARD_PASSWORD=change-me
# OR, more secure — bcrypt hash (takes precedence if set; leave password blank then):
# node -e "console.log(require('bcryptjs').hashSync('YOUR_PASSWORD',12))"
# DASHBOARD_PASSWORD_HASH=$2a$12$replace_with_your_bcrypt_hash

# The Apex state server (FastAPI on the VPS).
VPS_URL=http://localhost:8080
VPS_SECRET=change-me-to-match-the-algo-VPS_SECRET
