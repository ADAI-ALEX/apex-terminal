# ── Apex V4 Institutional — FTMO MT5 deployment config ─────────────────────
# Copy to `.env` on the VM (~/apex-v4/.env) and fill in the FTMO free-trial
# DEMO credentials. NEVER commit a filled .env.

# FTMO MT5 demo credentials (from the FTMO client area "free trial" email)
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=FTMO-Demo

# Path to the terminal INSIDE the Wine prefix (default mt5linux.sh location)
MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe

# Instrument symbols as named by FTMO (check Market Watch if these differ).
# FTMO-Demo indices use the .cash suffix; SP500m/US500 are NOT valid here —
# the live, ticking S&P 500 CFD is US500.cash (verified 2026-06-15).
BTC_SYMBOL=BTCUSD
US500_SYMBOL=US500.cash

# FTMO server timezone offset vs UTC (EET: +3 summer / +2 winter)
SERVER_UTC_OFFSET_HOURS=3

# Phase-5.4 deployment switch: true ONLY during the evaluation window.
# Flips the BTC leg between the two VALIDATED Phase-5.2 plateau corners
# (true: z0.8 / f0.01 / cap6 — false: z0.9 / f0.015 / cap4).
# Flip to false the day the account is funded.
CHALLENGE_MODE=true

# Order tagging — one magic per leg, never share across strategies
MAGIC_BTC=540401
MAGIC_US500=540402

# Engine poll cadence (seconds) for scale/trail management
POLL_SECONDS=10

# FTMO inactivity watchdog: nudge trade after N days with no account activity
# (FTMO closes accounts at 30 idle days; runs on the US500 leg only; 0=off)
WATCHDOG_DAYS=10
