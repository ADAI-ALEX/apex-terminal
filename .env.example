# ════════════════════════════════════════════════════════════
#  APEX ALGO — environment template
#  Copy to `.env` and fill in. NEVER commit the real .env.
#
#  EVERYTHING BELOW IS OPTIONAL. The system launches with ZERO config into the
#  Web-UI "Onboarding State": open the dashboard, enter your IG + Claude keys and
#  pick a risk profile there. Those are validated live and saved ENCRYPTED at rest
#  (~/.apex/runtime.json.enc via Fernet). Env vars, if set, take precedence over
#  the onboarding store — handy for a headless VPS / CI.
# ════════════════════════════════════════════════════════════

# ─── IG Markets (optional — or enter via the UI) ───────────
# Use a DEMO account for all development. LIVE only when fully tested.
IG_ACC_TYPE=DEMO                # DEMO | LIVE
IG_USERNAME=your_ig_username
IG_PASSWORD=your_ig_password
IG_API_KEY=your_ig_api_key
# Optional: pin a specific account id (otherwise the default is used)
IG_ACCOUNT_ID=

# ─── Claude API (Anthropic) (optional — or enter via the UI)─
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# ─── Risk profile / account (optional — set via the UI) ────
APEX_RISK_PROFILE=ig_standard   # ig_standard | prop_ftmo
APEX_STARTING_EQUITY=100000
APEX_ACCOUNT_CURRENCY=GBP
APEX_DAILY_TARGET_PCT=0.5

# ─── Cloud relay (run-anywhere mode) ───────────────────────
# When set, the laptop algo reads its config from Vercel KV and pushes live state
# back to it — so the Vercel dashboard works from anywhere with NO tunnel to your
# laptop. Attach a free Redis store in Vercel (Storage tab), then `vercel env pull`
# brings these down automatically (start.bat does this for you). Native Upstash
# names (UPSTASH_REDIS_REST_URL/TOKEN) are also accepted.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# ─── Onboarding / secrets-at-rest ──────────────────────────
# Fernet master key for the encrypted onboarding store. If unset, one is generated
# at ~/.apex/master.key on first save. On a VPS, set it here so the key lives in env.
# Generate: python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
# APEX_MASTER_KEY=
# Override the config dir (default ~/.apex):
# APEX_CONFIG_DIR=
# Dev escape hatch: skip the onboarding gate (starts heartbeat immediately in PAPER).
# APEX_SKIP_ONBOARDING=false

# ─── State server (read by the dashboard) ──────────────────
STATE_SERVER_HOST=0.0.0.0
STATE_SERVER_PORT=8080
# Shared secret — the dashboard must send this in the X-Apex-Secret header.
VPS_SECRET=change-me-to-a-long-random-string

# ─── Web UI ────────────────────────────────────────────────
# The dashboard URL start.bat opens on launch. Set to your Vercel deployment.
# Use DASHBOARD_URL=none to disable auto-opening a browser.
DASHBOARD_URL=https://apex-dashboard-pearl.vercel.app/

# ─── Runtime toggles ───────────────────────────────────────
# Master kill switch. When false, no orders are ever placed.
TRADING_ENABLED=true
# Comma-separated instrument keys to trade (see apex/config.py MARKETS).
ACTIVE_MARKETS=FTSE100,US500,DAX40,EURUSD,GBPUSD
LOG_LEVEL=INFO
