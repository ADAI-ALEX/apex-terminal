# ════════════════════════════════════════════════════════════
#  APEX ALGO — environment template
#  Copy to `.env` and fill in. NEVER commit the real .env.
# ════════════════════════════════════════════════════════════

# ─── IG Markets ────────────────────────────────────────────
# Use a DEMO account for all development. LIVE only when fully tested.
IG_ACC_TYPE=DEMO                # DEMO | LIVE
IG_USERNAME=your_ig_username
IG_PASSWORD=your_ig_password
IG_API_KEY=your_ig_api_key
# Optional: pin a specific account id (otherwise the default is used)
IG_ACCOUNT_ID=

# ─── Claude API (Anthropic) ────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# ─── State server (read by the dashboard) ──────────────────
STATE_SERVER_HOST=0.0.0.0
STATE_SERVER_PORT=8080
# Shared secret — the dashboard must send this in the X-Apex-Secret header.
VPS_SECRET=change-me-to-a-long-random-string

# ─── Runtime toggles ───────────────────────────────────────
# Master kill switch. When false, no orders are ever placed.
TRADING_ENABLED=true
# Comma-separated instrument keys to trade (see apex/config.py MARKETS).
ACTIVE_MARKETS=FTSE100,US500,DAX40,EURUSD,GBPUSD
LOG_LEVEL=INFO
